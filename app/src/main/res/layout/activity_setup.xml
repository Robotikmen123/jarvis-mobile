<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:text="J.A.R.V.I.S."
            android:textColor="@color/primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Initialisation"
            android:textColor="@color/textDim"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:text="GEMINI API KEY"
            android:textColor="@color/textDim"
            android:textSize="11sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <EditText
            android:id="@+id/etGemini"
            android:textColor="@color/text"
            android:textColorHint="@color/textDim"
            android:hint="AIza..."
            android:inputType="textPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:text="ANTHROPIC API KEY  (optional)"
            android:textColor="@color/textDim"
            android:textSize="11sp"
            android:layout_marginTop="14dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <EditText
            android:id="@+id/etAnthropic"
            android:textColor="@color/text"
            android:textColorHint="@color/textDim"
            android:hint="sk-ant-..."
            android:inputType="textPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:text="VOICE"
            android:textColor="@color/textDim"
            android:textSize="11sp"
            android:layout_marginTop="14dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <Spinner
            android:id="@+id/spVoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnSave"
            android:text="INITIALISE"
            android:textColor="#000d14"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp" />
    </LinearLayout>
</ScrollView>
