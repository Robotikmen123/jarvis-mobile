<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Full-screen animated HUD -->
    <com.jarvis.mobile.ui.HudView
        android:id="@+id/hud"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg" />

    <!-- Bottom overlay panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_panel"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <!-- Log terminal -->
        <TextView
            android:id="@+id/logView"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:padding="12dp"
            android:textSize="11sp"
            android:textColor="#9FE7FF"
            android:fontFamily="monospace"
            android:scrollbars="vertical"
            android:background="@drawable/bg_log"
            android:layout_marginBottom="10dp" />

        <!-- Text input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/input"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:hint="// konuş..."
                android:textColor="#BFF6FF"
                android:textColorHint="#558AA0"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:imeOptions="actionSend"
                android:maxLines="1" />

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp">

                <Button
                    android:id="@+id/sendBtn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="▶"
                    android:textSize="14sp"
                    android:textColor="#001218"
                    android:textStyle="bold"
                    android:background="@drawable/bg_send"
                    android:stateListAnimator="@null"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />
            </FrameLayout>
        </LinearLayout>

        <!-- Control buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/muteBtn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="🎙  MIC"
                android:textSize="12sp"
                android:textColor="#00D4FF"
                android:background="@drawable/bg_ctrl_btn"
                android:stateListAnimator="@null" />

            <Space
                android:layout_width="8dp"
                android:layout_height="match_parent" />

            <Button
                android:id="@+id/settingsBtn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="⚙  SETTINGS"
                android:textSize="12sp"
                android:textColor="#7FBFD0"
                android:background="@drawable/bg_ctrl_btn"
                android:stateListAnimator="@null" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
